# Server configuration
PORT=5000
NODE_ENV=development

# MySQL Database configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=tata_supply_chain

# MongoDB configuration
# Fallback to local if empty: mongodb://localhost:27017/tata_supply_chain
MONGODB_URI=mongodb://localhost:27017/tata_supply_chain

# JWT configuration
JWT_SECRET=tata_supply_chain_secret_key_change_in_production
JWT_EXPIRES_IN=7d
